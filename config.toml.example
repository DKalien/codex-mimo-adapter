# IMPORTANT:
# Merge this provider block into the user-level Codex configuration:
#   Windows: %USERPROFILE%\.codex\config.toml
# Do not place model_providers in this project's .codex/config.toml.
# Codex ignores project-level model provider definitions.
#
# The `init` command creates a single mimo_adapter provider
# for all projects.  Each project carries its own CODEX_MIMO_PROJECT_ID
# in .codex-mimo-adapter.env for isolation at the adapter level.

[model_providers.mimo_adapter]
name = "MiMo Token Plan Adapter"
base_url = "http://127.0.0.1:4010/v1"
wire_api = "responses"
request_max_retries = 0
stream_max_retries = 0
stream_idle_timeout_ms = 120000

[model_providers.mimo_adapter.auth]
command = "codex-mimo-adapter"
args = ["auth", "print-local-token"]
timeout_ms = 5000

# These entries match the nine files installed by `codex-mimo-adapter init`.
# Keep this list aligned with resources/templates/ and .codex/agents/.
[agents.default]
description = "MiMo-backed general-purpose fallback subagent"
config_file = ".codex/agents/default.toml"

[agents.explorer]
description = "MiMo-backed read-only explorer"
config_file = ".codex/agents/explorer.toml"

[agents.worker]
description = "MiMo-backed bounded implementation worker"
config_file = ".codex/agents/worker.toml"

[agents.oss_worker_pro_analysis]
description = "MiMo Pro worker for complex analysis and architecture tradeoffs"
config_file = ".codex/agents/oss-worker-pro-1.toml"

[agents.oss_worker_pro_implementation]
description = "MiMo Pro worker for complex implementation and integration"
config_file = ".codex/agents/oss-worker-pro-2.toml"

[agents.oss_worker_pro_review]
description = "MiMo Pro read-only worker for independent review"
config_file = ".codex/agents/oss-worker-pro-3.toml"

[agents.oss_worker_std_implementation]
description = "MiMo standard worker for bounded implementation and multimodal tasks"
config_file = ".codex/agents/oss-worker-std-1.toml"

[agents.oss_worker_std_test]
description = "MiMo standard worker for focused tests and verification"
config_file = ".codex/agents/oss-worker-std-2.toml"

[agents.oss_worker_std_docs]
description = "MiMo standard worker for documentation and lightweight maintenance"
config_file = ".codex/agents/oss-worker-std-3.toml"
